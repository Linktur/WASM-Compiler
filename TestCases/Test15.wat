(module
  (import "env" "print_i32" (func $print_i32 (param i32)))
  (import "env" "print_f64" (func $print_f64 (param f64)))
  
  (memory 1)
  
  (func $setfirst (param $a i32)
    (local.get $a)
    (i32.const 1)
    (i32.const 1)
    (i32.sub)
    (i32.const 4)
    (i32.mul)
    (i32.add)
    (i32.const 111)
    (i32.store)
  )
  
  (func $main (export "main")
    (local $x i32)
    (i32.const 0)
    (local.set $x)
    (local.get $x)
    (i32.const 1)
    (i32.const 1)
    (i32.sub)
    (i32.const 4)
    (i32.mul)
    (i32.add)
    (i32.const 10)
    (i32.store)
    (local.get $x)
    (i32.const 2)
    (i32.const 1)
    (i32.sub)
    (i32.const 4)
    (i32.mul)
    (i32.add)
    (i32.const 20)
    (i32.store)
    (local.get $x)
    (i32.const 3)
    (i32.const 1)
    (i32.sub)
    (i32.const 4)
    (i32.mul)
    (i32.add)
    (i32.const 30)
    (i32.store)
    (local.get $x)
    (call $setfirst)
    (local.get $x)
    (i32.const 1)
    (i32.const 1)
    (i32.sub)
    (i32.const 4)
    (i32.mul)
    (i32.add)
    (i32.load)
    (call $print_i32)
  )
  
)
